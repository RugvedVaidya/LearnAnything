generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  USER
  ADMIN
}

enum Difficulty {
  BEGINNER
  INTERMEDIATE
  ADVANCED
}

enum CourseStatus {
  GENERATING
  READY
  FAILED
}

model User {
  id String @id @default(cuid())

  name String

  email String @unique

  password String

  avatar String?

  role UserRole @default(USER)

  createdAt DateTime @default(now())

  updatedAt DateTime @updatedAt

  courses        Course[]
  userPreference UserPreference?
}

model Course {

  id               String   @id @default(cuid())

  title            String

  description      String?

  difficulty       Difficulty

  estimatedHours   Int

  status           CourseStatus @default(GENERATING)

  createdAt        DateTime @default(now())

  userId           String

  user             User @relation(fields: [userId], references: [id])

  modules          Module[]
}

model Module {
  id String @id @default(cuid())

  title String

  description String?

  order Int

  estimatedTime Int

  courseId String

  course Course @relation(fields: [courseId], references: [id])

  chapters Chapter[]
}

model Chapter {
  id String @id @default(cuid())

  title String

  description String?

  order Int

  moduleId String

  module Module @relation(fields: [moduleId], references: [id])

  lessons Lesson[]
}

model Lesson {
  id String @id @default(cuid())

  title String

  summary String?

  difficulty String

  readingTime Int

  order Int

  chapterId String

  chapter Chapter @relation(fields: [chapterId], references: [id])
}

model UserPreference {
  id String @id @default(cuid())

  theme String @default("dark")

  language String @default("en")

  timezone String?

  userId String @unique

  user User @relation(fields: [userId], references: [id])
}


